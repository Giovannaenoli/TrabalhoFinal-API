        {
          "name": "2. Fazer Login (Obter Token JWT)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set(\"token\", jsonData.token);",
                  "console.log(\"Token JWT obtido e salvo na variável de ambiente: \" + pm.environment.get(\"token\"));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"giovanna.teste@email.com\",\n  \"senha\": \"senha123\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/auth/login",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3000",
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Faz login com um usuário existente e salva o token JWT em uma variável de ambiente do Postman ({{token}})."
          },
          "response": []
        }
